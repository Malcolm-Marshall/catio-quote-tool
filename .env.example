UNWRANGLE_CEDAR_THICKNESS_INCHES=2
UNWRANGLE_CEDAR_WIDTH_INCHES=4
UNWRANGLE_CEDAR_LENGTH_FEET=8
UNWRANGLE_REDWOOD_PRODUCT_URL=
UNWRANGLE_REDWOOD_THICKNESS_INCHES=2
UNWRANGLE_REDWOOD_WIDTH_INCHES=4
UNWRANGLE_REDWOOD_LENGTH_FEET=8

