LOWES_CEDAR_WIDTH_INCHES=4
LOWES_CEDAR_LENGTH_FEET=8
LOWES_REDWOOD_PRODUCT_ID=
LOWES_REDWOOD_THICKNESS_INCHES=2
LOWES_REDWOOD_WIDTH_INCHES=4
